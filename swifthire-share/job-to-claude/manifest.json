{
  "manifest_version": 3,
  "name": "SwiftHire",
  "version": "1.2",
  "description": "Job application automation",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "downloads", "notifications", "debugger"],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SwiftHire"
  },
  "background": {
    "service_worker": "background.js"
  }
}
