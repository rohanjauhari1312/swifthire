<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.swifthire.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <!-- EDIT this path to where you put swifthire_server.py -->
        <string>/Users/YOU/swifthire/server/swifthire_server.py</string>
    </array>
    <key>KeepAlive</key><true/>
    <key>RunAtLoad</key><true/>
    <key>StandardOutPath</key><string>/tmp/swifthire-server.log</string>
    <key>StandardErrorPath</key><string>/tmp/swifthire-server.log</string>
</dict>
</plist>
